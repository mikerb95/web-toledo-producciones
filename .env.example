# Contraseña única del panel de administración (/admin)
ADMIN_PASSWORD="cambia-esta-clave"

# Secreto para firmar la cookie de sesión del admin (cualquier cadena larga y aleatoria)
SESSION_SECRET="genera-un-secreto-largo-aleatorio"

# Base de datos Turso (libSQL).
# En local puedes dejar TURSO_DATABASE_URL apuntando a un archivo SQLite local:
#   TURSO_DATABASE_URL="file:./local.db"
# En producción (Vercel) usa la URL y el token de tu base Turso:
#   TURSO_DATABASE_URL="libsql://tu-base.turso.io"
#   TURSO_AUTH_TOKEN="ey..."
TURSO_DATABASE_URL="file:./local.db"
TURSO_AUTH_TOKEN=""
