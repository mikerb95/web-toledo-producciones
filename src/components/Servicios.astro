---
import Equalizer from './Equalizer.astro';
import type { ViewModel } from '../lib/viewmodel';
interface Props { vm: ViewModel; }
const { vm } = Astro.props;
const iconBars = [
  { h: 7, dur: 1.1, delay: -0.1 }, { h: 14, dur: 1.3, delay: -0.5 },
  { h: 9, dur: 0.9, delay: -0.3 }, { h: 12, dur: 1.2, delay: -0.7 },
];
---
<section id="servicios" style="position:relative;background:#08080a;padding:clamp(70px,9vw,120px) clamp(20px,5vw,48px)">
  <div style="max-width:1180px;margin:0 auto">
    <div data-rev="up" style="max-width:640px;margin-bottom:54px">
      <div data-i18n="t.serv.kicker" style="font-size:12px;letter-spacing:2.5px;text-transform:uppercase;color:#E2C277;font-weight:600;margin-bottom:14px">{vm.t.serv.kicker}</div>
      <h2 data-i18n="t.serv.title" style="font-family:var(--font-display);font-weight:700;font-size:clamp(28px,4.4vw,46px);line-height:1.04;letter-spacing:-1px;margin:0 0 16px;color:#F4EFE3">{vm.t.serv.title}</h2>
      <p data-i18n="t.serv.sub" style="font-size:16px;line-height:1.6;color:#a09a8f;margin:0">{vm.t.serv.sub}</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(248px,1fr));gap:16px">
      {vm.t.serv.items.map((item, i) => (
        <div class="serv-card" data-rev="fade" style="background:linear-gradient(180deg,rgba(255,255,255,.035),rgba(255,255,255,.012));border:1px solid rgba(255,255,255,.08);border-radius:18px;padding:26px 24px;transition:border-color .3s,transform .3s">
          <div style="width:46px;height:46px;border-radius:12px;background:radial-gradient(120% 120% at 30% 20%,rgba(244,199,82,.22),rgba(226,168,46,.05));border:1px solid rgba(226,168,46,.35);display:flex;align-items:center;justify-content:center;margin-bottom:18px">
            <Equalizer bars={iconBars} width={3} height={16} gap={2} fill="#F4C752" radius={1} />
          </div>
          <h3 data-i18n={`t.serv.items.${i}.t`} style="font-family:var(--font-display);font-weight:600;font-size:18.5px;margin:0 0 9px;color:#F4EFE3">{item.t}</h3>
          <p data-i18n={`t.serv.items.${i}.d`} style="font-size:14px;line-height:1.6;color:#9a948a;margin:0">{item.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>.serv-card:hover { border-color: rgba(226,168,46,.45); transform: translateY(-4px); }</style>
