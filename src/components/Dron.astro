---
import { Image } from 'astro:assets';
import type { ViewModel } from '../lib/viewmodel';
import dronImg from '../assets/dron-aerial.svg';
interface Props { vm: ViewModel; }
const { vm } = Astro.props;
const d = vm.t.drone;
const stats = [
  { s: d.s1, v: d.v1, key: 's1', vkey: 'v1' },
  { s: d.s2, v: d.v2, key: 's2', vkey: 'v2' },
  { s: d.s3, v: d.v3, key: 's3', vkey: 'v3' },
  { s: d.s4, v: d.v4, key: 's4', vkey: 'v4' },
];
---
<section id="dron" style="position:relative;background:#08080a;padding:clamp(70px,9vw,120px) clamp(20px,5vw,48px);overflow:hidden">
  <div style="position:absolute;top:10%;right:-6%;width:520px;height:520px;border-radius:50%;background:radial-gradient(circle,rgba(244,199,82,.12),transparent 65%);filter:blur(30px);pointer-events:none"></div>
  <div style="max-width:1180px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(330px,1fr));gap:clamp(36px,6vw,72px);align-items:center">
    <div data-rev="up">
      <div style="display:inline-flex;align-items:center;gap:8px;font-size:12px;letter-spacing:2.5px;text-transform:uppercase;color:#F4C752;font-weight:600;margin-bottom:18px"><span style="width:6px;height:6px;border-radius:50%;background:#F4C752;box-shadow:0 0 10px #F4C752;animation:pulseDot 1.6s ease-in-out infinite"></span><span data-i18n="t.drone.kicker">{d.kicker}</span></div>
      <h2 data-i18n="t.drone.title" style="font-family:var(--font-display);font-weight:700;font-size:clamp(30px,5vw,52px);line-height:1.02;letter-spacing:-1.2px;margin:0 0 18px;color:#F4EFE3">{d.title}</h2>
      <p data-i18n="t.drone.sub" style="font-size:16.5px;line-height:1.65;color:#a8a293;margin:0 0 30px;max-width:520px">{d.sub}</p>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;max-width:460px;margin-bottom:32px">
        {stats.map((st) => (
          <div style="border:1px solid rgba(255,255,255,.1);border-radius:14px;padding:16px 18px;background:rgba(255,255,255,.02)">
            <div data-i18n={`t.drone.${st.key}`} style="font-size:11px;letter-spacing:1px;text-transform:uppercase;color:#7d786f;margin-bottom:6px">{st.s}</div>
            <div data-i18n={`t.drone.${st.vkey}`} style="font-family:var(--font-display);font-weight:700;font-size:22px;color:#F4C752">{st.v}</div>
          </div>
        ))}
      </div>
      <a href="#paquetes" style="display:inline-flex;align-items:center;gap:9px;background:linear-gradient(180deg,#F4C752,#D89A24);color:#1a1206;font-weight:700;font-size:15px;padding:14px 26px;border-radius:999px;box-shadow:0 10px 30px rgba(226,168,46,.3)"><span data-i18n="t.drone.cta">{d.cta}</span> <span style="font-size:17px">→</span></a>
    </div>

    <div data-rev="fade" style="position:relative">
      <div style="position:relative;width:100%;aspect-ratio:4/3;border-radius:20px;overflow:hidden;border:1px solid rgba(244,199,82,.28);box-shadow:0 30px 80px rgba(0,0,0,.5)">
        <Image src={dronImg} alt="Toma aérea con dron" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover" />
        <!-- HUD overlay -->
        <div style="position:absolute;inset:0;pointer-events:none;z-index:3">
          <div style="position:absolute;top:14px;left:14px;width:30px;height:30px;border-left:2px solid rgba(244,199,82,.85);border-top:2px solid rgba(244,199,82,.85);border-top-left-radius:4px"></div>
          <div style="position:absolute;top:14px;right:14px;width:30px;height:30px;border-right:2px solid rgba(244,199,82,.85);border-top:2px solid rgba(244,199,82,.85);border-top-right-radius:4px"></div>
          <div style="position:absolute;bottom:14px;left:14px;width:30px;height:30px;border-left:2px solid rgba(244,199,82,.85);border-bottom:2px solid rgba(244,199,82,.85);border-bottom-left-radius:4px"></div>
          <div style="position:absolute;bottom:14px;right:14px;width:30px;height:30px;border-right:2px solid rgba(244,199,82,.85);border-bottom:2px solid rgba(244,199,82,.85);border-bottom-right-radius:4px"></div>
          <div style="position:absolute;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(244,199,82,.7),transparent);animation:scanline 4s ease-in-out infinite"></div>
          <div style="position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:62px;height:62px;border:1px solid rgba(244,199,82,.7);border-radius:50%;animation:reticle 2.4s ease-in-out infinite"></div>
          <div style="position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:1px;height:20px;background:rgba(244,199,82,.7)"></div>
          <div style="position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:20px;height:1px;background:rgba(244,199,82,.7)"></div>
          <div style="position:absolute;top:16px;left:50%;transform:translateX(-50%);display:flex;align-items:center;gap:7px;background:rgba(8,8,10,.6);border:1px solid rgba(255,90,77,.5);border-radius:999px;padding:5px 11px;font-family:var(--font-display);font-size:10.5px;letter-spacing:1.5px;color:#ffd9d4"><span style="width:7px;height:7px;border-radius:50%;background:#ff5a4d;box-shadow:0 0 8px #ff5a4d;animation:pulseDot 1.2s ease-in-out infinite"></span><span data-i18n="t.drone.hud">{d.hud}</span></div>
          <div style="position:absolute;bottom:16px;left:16px;font-family:var(--font-display);font-size:11px;letter-spacing:1px;color:#F4C752;animation:hudData 2.6s ease-in-out infinite">ALT 40m · 4K60</div>
          <div style="position:absolute;bottom:16px;right:16px;font-family:var(--font-display);font-size:11px;letter-spacing:1px;color:#F4C752;animation:hudData 3.1s ease-in-out infinite">4.7106° N · 74.07° W</div>
        </div>
      </div>
    </div>
  </div>
</section>
