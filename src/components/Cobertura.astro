---
import type { ViewModel } from '../lib/viewmodel';
interface Props { vm: ViewModel; }
const { vm } = Astro.props;
---
<section id="cobertura" class="checker-bg" style="position:relative;padding:clamp(70px,9vw,120px) clamp(20px,5vw,48px);border-top:1px solid rgba(226,168,46,.1);overflow:hidden">
  <div style="max-width:1180px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:clamp(36px,6vw,64px);align-items:center">
    <div data-rev="up">
      <div data-i18n="t.cov.kicker" style="font-size:12px;letter-spacing:2.5px;text-transform:uppercase;color:#E2C277;font-weight:600;margin-bottom:14px">{vm.t.cov.kicker}</div>
      <h2 data-i18n="t.cov.title" style="font-family:var(--font-display);font-weight:700;font-size:clamp(28px,4.4vw,46px);line-height:1.04;letter-spacing:-1px;margin:0 0 16px;color:#F4EFE3">{vm.t.cov.title}</h2>
      <p data-i18n="t.cov.sub" style="font-size:16px;line-height:1.65;color:#a09a8f;margin:0 0 26px;max-width:480px">{vm.t.cov.sub}</p>
      <div id="coverage-chips" style="display:flex;flex-wrap:wrap;gap:9px;max-width:520px">
        {vm.coverage.map((c) => (
          <span style="display:inline-flex;align-items:center;gap:7px;border:1px solid rgba(226,168,46,.28);background:rgba(226,168,46,.05);border-radius:999px;padding:8px 14px;font-size:13.5px;font-weight:600;color:#d8d2c6"><span style="width:5px;height:5px;border-radius:50%;background:#E2A82E"></span>{c}</span>
        ))}
      </div>
    </div>
    <div data-rev="fade" style="position:relative;display:flex;align-items:center;justify-content:center;min-height:340px">
      <div style="position:absolute;width:340px;height:340px;border:1px solid rgba(226,168,46,.12);border-radius:50%"></div>
      <div style="position:absolute;width:240px;height:240px;border:1px solid rgba(226,168,46,.18);border-radius:50%"></div>
      <div style="position:absolute;width:140px;height:140px;border:1px solid rgba(226,168,46,.26);border-radius:50%"></div>
      <div style="position:absolute;width:340px;height:340px;border-radius:50%;background:conic-gradient(from 0deg,rgba(244,199,82,.22),transparent 28%);animation:beamSpin 7s linear infinite"></div>
      <div style="position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;gap:8px">
        <div style="width:16px;height:16px;border-radius:50%;background:#F4C752;box-shadow:0 0 18px rgba(244,199,82,.8)"></div>
        <div style="font-family:var(--font-display);font-weight:700;font-size:15px;letter-spacing:.5px;color:#F7F2E6">Bogotá</div>
      </div>
      <div style="position:absolute;top:30%;left:24%;width:8px;height:8px;border-radius:50%;background:#E2A82E;opacity:.7;animation:pulseDot 2.2s ease-in-out infinite"></div>
      <div style="position:absolute;top:64%;left:30%;width:8px;height:8px;border-radius:50%;background:#E2A82E;opacity:.7;animation:pulseDot 2.6s ease-in-out infinite"></div>
      <div style="position:absolute;top:36%;right:22%;width:8px;height:8px;border-radius:50%;background:#E2A82E;opacity:.7;animation:pulseDot 2.9s ease-in-out infinite"></div>
      <div style="position:absolute;bottom:24%;right:30%;width:8px;height:8px;border-radius:50%;background:#E2A82E;opacity:.7;animation:pulseDot 2.4s ease-in-out infinite"></div>
    </div>
  </div>
</section>
