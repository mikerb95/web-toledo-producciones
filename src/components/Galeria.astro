---
import type { ViewModel } from '../lib/viewmodel';
interface Props { vm: ViewModel; }
const { vm } = Astro.props;
// 7 slots; 1 y 5 ocupan dos filas (igual que el prototipo).
const spans = [2, 1, 1, 1, 2, 1, 1];
---
<section id="galeria" style="position:relative;background:#08080a;padding:clamp(70px,9vw,120px) clamp(20px,5vw,48px)">
  <div style="max-width:1180px;margin:0 auto">
    <div data-rev="up" style="max-width:640px;margin-bottom:44px">
      <div data-i18n="t.gal.kicker" style="font-size:12px;letter-spacing:2.5px;text-transform:uppercase;color:#E2C277;font-weight:600;margin-bottom:14px">{vm.t.gal.kicker}</div>
      <h2 data-i18n="t.gal.title" style="font-family:var(--font-display);font-weight:700;font-size:clamp(28px,4.4vw,46px);line-height:1.04;letter-spacing:-1px;margin:0 0 14px;color:#F4EFE3">{vm.t.gal.title}</h2>
      <p data-i18n="t.gal.sub" style="font-size:15.5px;line-height:1.6;color:#a09a8f;margin:0">{vm.t.gal.sub}</p>
    </div>
    <div data-rev="fade" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));grid-auto-rows:190px;gap:14px">
      {spans.map((span) => (
        <div style={`grid-row:span ${span};border-radius:18px;overflow:hidden;position:relative;border:1px solid rgba(255,255,255,.07);background:radial-gradient(120% 120% at 30% 20%,rgba(244,199,82,.07),transparent 60%),linear-gradient(160deg,#13100b,#0a0a0c)`}>
          <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:#3a352c;font-size:11.5px;letter-spacing:1.5px;text-transform:uppercase;text-align:center;padding:0 16px" data-i18n="t.gal.ph">{vm.t.gal.ph}</div>
        </div>
      ))}
    </div>
  </div>
</section>
