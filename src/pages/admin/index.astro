---
import Base from '../../layouts/Base.astro';
import { getContent } from '../../lib/content';
import { DEFAULTS } from '../../data/defaults';

export const prerender = false;

const authed = Astro.locals.authed;
const content = authed ? await getContent() : null;
const bootstrap = authed ? JSON.stringify({ content, defaults: DEFAULTS }) : '';
---

<Base title="Admin · Toledo Producciones">
  {!authed && (
    <div class="checker-bg" style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px;background-size:54px 54px;background-position:0 0,27px 27px">
      <div style="width:100%;max-width:400px;animation:fadeUp .5s ease both">
        <div style="display:flex;flex-direction:column;align-items:center;margin-bottom:30px">
          <div style="display:flex;align-items:flex-end;gap:8px">
            <span class="gold-text" style="font-family:var(--font-display);font-weight:700;font-size:30px;letter-spacing:-.5px">Toledo</span>
            <span style="font-size:10px;letter-spacing:4px;font-weight:600;color:#9a948a;padding-bottom:5px">PRODUCCIONES</span>
          </div>
          <div style="margin-top:8px;font-size:12.5px;letter-spacing:2px;text-transform:uppercase;color:#7d786f">Panel de administración</div>
        </div>
        <form id="login-form" style="background:linear-gradient(180deg,rgba(255,255,255,.045),rgba(255,255,255,.012));border:1px solid rgba(255,255,255,.1);border-radius:20px;padding:28px">
          <label style="display:block;margin-bottom:16px">
            <span style="display:block;font-size:12px;font-weight:600;color:#a8a293;margin-bottom:7px">Contraseña</span>
            <input id="login-pass" type="password" placeholder="••••••••" class="adm-input" />
          </label>
          <div id="login-err" hidden style="color:#ff8a7d;font-size:13px;margin:6px 0 0"></div>
          <button type="submit" style="margin-top:18px;width:100%;background:linear-gradient(180deg,#F4C752,#D89A24);color:#1a1206;font-weight:700;font-size:15px;padding:14px;border:none;border-radius:12px;cursor:pointer;box-shadow:0 10px 28px rgba(226,168,46,.3)">Entrar al panel</button>
        </form>
        <div style="text-align:center;margin-top:18px"><a href="/" style="color:#7d786f;font-size:13px">← Volver al sitio</a></div>
      </div>
    </div>
  )}

  {authed && (
    <div style="min-height:100vh;display:flex">
      <aside style="width:248px;flex-shrink:0;background:#0c0c0f;border-right:1px solid rgba(255,255,255,.08);padding:24px 18px;display:flex;flex-direction:column;position:sticky;top:0;height:100vh">
        <div style="display:flex;align-items:flex-end;gap:7px;padding:0 6px 22px">
          <span class="gold-text" style="font-family:var(--font-display);font-weight:700;font-size:22px">Toledo</span>
          <span style="font-size:8px;letter-spacing:3px;font-weight:600;color:#9a948a;padding-bottom:4px">ADMIN</span>
        </div>
        <nav style="display:flex;flex-direction:column;gap:4px">
          <button type="button" class="adm-nav" data-tab="paquetes"><span style="font-size:15px">◆</span> Paquetes</button>
          <button type="button" class="adm-nav" data-tab="hero"><span style="font-size:15px">✦</span> Portada</button>
          <button type="button" class="adm-nav" data-tab="contacto"><span style="font-size:15px">✆</span> Contacto y cobertura</button>
        </nav>
        <div style="margin-top:auto;display:flex;flex-direction:column;gap:8px;padding-top:18px;border-top:1px solid rgba(255,255,255,.07)">
          <a href="/" target="_blank" class="adm-side-btn">↗ Ver sitio</a>
          <button type="button" id="adm-export" class="adm-side-btn">⤓ Exportar JSON</button>
          <button type="button" id="adm-logout" class="adm-side-btn" style="border:none;color:#9a948a">⎋ Cerrar sesión</button>
        </div>
      </aside>

      <main style="flex:1;min-width:0;display:flex;flex-direction:column;height:100vh;overflow:hidden">
        <div style="flex-shrink:0;display:flex;align-items:center;justify-content:space-between;gap:16px;padding:18px clamp(20px,4vw,40px);border-bottom:1px solid rgba(255,255,255,.08);background:rgba(10,10,12,.7);backdrop-filter:blur(10px)">
          <div>
            <div id="adm-title" style="font-family:var(--font-display);font-weight:700;font-size:19px;color:#F4EFE3"></div>
            <div id="adm-sub" style="font-size:12.5px;color:#7d786f"></div>
          </div>
          <div style="display:flex;align-items:center;gap:12px">
            <span id="adm-dirty" hidden style="font-size:12.5px;color:#E2C277;display:flex;align-items:center;gap:6px"><span style="width:7px;height:7px;border-radius:50%;background:#E2A82E"></span>Cambios sin guardar</span>
            <button type="button" id="adm-reset" style="font-size:13px;font-weight:600;color:#9a948a;background:none;border:1px solid rgba(255,255,255,.12);padding:10px 15px;border-radius:10px;cursor:pointer">Restablecer</button>
            <button type="button" id="adm-save" style="font-size:14px;font-weight:700;color:#1a1206;background:linear-gradient(180deg,#F4C752,#D89A24);border:none;padding:11px 22px;border-radius:10px;cursor:pointer;box-shadow:0 8px 22px rgba(226,168,46,.28)">Guardar cambios</button>
          </div>
        </div>
        <div style="flex:1;overflow-y:auto;padding:clamp(22px,4vw,40px)">
          <div id="admin-root" style="max-width:900px;margin:0 auto"></div>
        </div>
      </main>

      <div id="adm-toast" hidden style="position:fixed;bottom:26px;left:50%;transform:translateX(-50%);z-index:50;display:flex;align-items:center;gap:10px;background:linear-gradient(180deg,#F4C752,#D89A24);color:#1a1206;font-weight:700;font-size:14px;padding:13px 22px;border-radius:999px;box-shadow:0 14px 40px rgba(226,168,46,.4);animation:toastIn .35s ease both">✓ Cambios guardados — el sitio ya está actualizado</div>

      <script type="application/json" id="admin-bootstrap" set:html={bootstrap} is:inline></script>
      <script>import '../../scripts/admin';</script>
    </div>
  )}

  <script>import '../../scripts/login';</script>
</Base>

<style is:global>
  .adm-input { width: 100%; background: rgba(8,8,10,.6); border: 1px solid rgba(255,255,255,.14); border-radius: 11px; padding: 13px 15px; color: #ECE7DC; font-size: 14.5px; outline: none; font-family: inherit; }
  .adm-input:focus { border-color: #E2A82E; }
  .adm-nav { display: flex; align-items: center; gap: 10px; font-size: 14px; font-weight: 600; font-family: inherit; text-align: left; padding: 11px 13px; border-radius: 11px; cursor: pointer; border: 1px solid transparent; background: transparent; color: #9a948a; }
  .adm-nav[aria-current='true'] { background: linear-gradient(180deg, rgba(244,199,82,.16), rgba(226,168,46,.06)); color: #F4C752; border-color: rgba(226,168,46,.3); }
  .adm-side-btn { display: flex; align-items: center; gap: 9px; color: #cdc7bc; font-size: 13.5px; font-weight: 600; background: none; padding: 10px 12px; border-radius: 10px; border: 1px solid rgba(255,255,255,.1); cursor: pointer; text-align: left; text-decoration: none; font-family: inherit; }
  .adm-side-btn:hover { border-color: rgba(226,168,46,.4); }
  .adm-card { background: linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.012)); border: 1px solid rgba(255,255,255,.1); border-radius: 18px; }
  .adm-lbl { display: block; font-size: 11.5px; font-weight: 600; letter-spacing: .4px; color: #8b867c; margin-bottom: 7px; text-transform: uppercase; }
  .adm-field { width: 100%; background: rgba(8,8,10,.6); border: 1px solid rgba(255,255,255,.13); border-radius: 10px; padding: 11px 13px; color: #ECE7DC; font-size: 14px; outline: none; font-family: inherit; }
  .adm-field:focus { border-color: #E2A82E; }
  .adm-field-sm { flex: 1; min-width: 0; background: rgba(8,8,10,.6); border: 1px solid rgba(255,255,255,.13); border-radius: 9px; padding: 9px 11px; color: #ECE7DC; font-size: 13px; outline: none; font-family: inherit; }
  .adm-del { flex-shrink: 0; width: 30px; height: 30px; border-radius: 8px; background: rgba(255,138,125,.08); border: 1px solid rgba(255,138,125,.25); color: #ff8a7d; cursor: pointer; font-size: 12px; }
  .adm-add { margin-top: 2px; align-self: flex-start; background: rgba(226,168,46,.08); border: 1px dashed rgba(226,168,46,.4); color: #E2C277; font-size: 12.5px; font-weight: 600; padding: 8px 12px; border-radius: 9px; cursor: pointer; font-family: inherit; }
  .adm-swatch { width: 30px; height: 30px; border-radius: 8px; cursor: pointer; }
</style>
