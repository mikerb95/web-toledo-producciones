---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Servicios from '../components/Servicios.astro';
import Paquetes from '../components/Paquetes.astro';
import Dron from '../components/Dron.astro';
import Eventos from '../components/Eventos.astro';
import Galeria from '../components/Galeria.astro';
import Cobertura from '../components/Cobertura.astro';
import Contacto from '../components/Contacto.astro';
import Footer from '../components/Footer.astro';
import { getContent } from '../lib/content';
import { buildVM } from '../lib/viewmodel';

// SSR: el contenido se lee de la BD en cada request, así las ediciones del
// admin se reflejan para todos. Render inicial en ES; el toggle cliente
// intercambia a EN usando el store embebido.
const content = await getContent();
const vmEs = buildVM(content, 'es');
const vmEn = buildVM(content, 'en');
const store = JSON.stringify({ es: vmEs, en: vmEn });
---

<Base>
  <div style="position:relative;min-height:100vh;background:#08080a;overflow:hidden">
    <Nav vm={vmEs} />
    <Hero vm={vmEs} />
    <Servicios vm={vmEs} />
    <Paquetes vm={vmEs} />
    <Dron vm={vmEs} />
    <Eventos vm={vmEs} />
    <Galeria vm={vmEs} />
    <Cobertura vm={vmEs} />
    <Contacto vm={vmEs} />
    <Footer vm={vmEs} />
  </div>

  <script id="toledo-data" type="application/json" set:html={store} is:inline></script>

  <script>
    import '../scripts/lang-toggle';
    import '../scripts/package-modal';
    import '../scripts/contact-form';
    import '../scripts/reveal';
  </script>
</Base>
